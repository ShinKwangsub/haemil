# macOS
.DS_Store
.AppleDouble
.LSOverride

# Reference sources (7 open-source platforms — cloned locally, ~1.6GB)
reference/

# Build artifacts — anchored with leading slash so cmd/haemil/ is NOT ignored
/haemil
/haemil.exe
*.exe
/dist/
/build/
/bin/
/tmp/

# Go
*.test
*.out
vendor/

# Node / TypeScript
node_modules/
*.tsbuildinfo

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.pytest_cache/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log
logs/

# Environment variables (secrets)
.env
.env.*
!.env.example

# Session data
.haemil/
~/.haemil/

# Graphify — commit outputs, ignore per-file extraction cache and internal state
graphify-out/cache/
graphify-out/.graphify_*
